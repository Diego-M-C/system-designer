      "audit": {
        "completeness_rule": "every entry has service AND started_at AND status; resolved entries have resolved_at AND rca",
        "missing_threshold_pct": 1,
        "particular_audit": "every alert event emits an entry",
        "global_audit": "every 30 days: surface unresolved incidents older than 7 days"
