{
  "starter_id": "public_sector",
  "schema_version": 1,
  "generator_version": "0.3.2",
  "domain": "public_sector",
  "description": "Starter for public-sector / e-government projects. Anchored on policy traceability and citizen-feedback discipline.",
  "modules": [
    {
      "name": "policy_changes_tracked",
      "format": "jsonl",
      "path": "memory/policy_changes_tracked.jsonl",
      "trigger": "every policy update detected (own or upstream)",
      "append_only": true,
      "fields": [
        {
          "name": "policy_id",
          "type": "string",
          "flag": "mandatory",
          "rationale": "stable handle",
          "confidence_pct": 95
        },
        {
          "name": "policy_name",
          "type": "string",
          "flag": "mandatory",
          "rationale": "search key",
          "confidence_pct": 92
        },
        {
          "name": "change_type",
          "type": "enum {add,amend,supersede,repeal}",
          "flag": "mandatory",
          "rationale": "lifecycle",
          "confidence_pct": 95
        },
        {
          "name": "effective_date",
          "type": "ISO8601",
          "flag": "mandatory",
          "rationale": "applicability",
          "confidence_pct": 92
        },
        {
          "name": "summary",
          "type": "string",
          "flag": "mandatory",
          "rationale": "≤300 chars",
          "confidence_pct": 88
        },
        {
          "name": "impact_score",
          "type": "int 1-5",
          "flag": "mandatory",
          "rationale": "self-rated",
          "confidence_pct": 85
        },
        {
          "name": "session_id",
          "type": "string",
          "flag": "mandatory",
          "rationale": "lineage",
          "confidence_pct": 95
        },
        {
          "name": "ts",
          "type": "ISO8601",
          "flag": "mandatory",
          "rationale": "ordering",
          "confidence_pct": 95
        }
      ],
      "audit": {
        "completeness_rule": "every entry has policy_name AND change_type AND effective_date AND summary AND impact_score",
        "missing_threshold_pct": 5,
        "particular_audit": "every Gate #2 reflection includes a policy_changes_tracked review",
        "global_audit": "every 30 days: surface high-impact (>=4) changes without compliance_audit_trail follow-up"
      },
      "added_by": "starter",
      "confidence_pct": 85,
      "non_removable_for_high_risk": true
    },
    {
      "name": "citizen_feedback_categories",
      "format": "jsonl",
      "path": "memory/citizen_feedback_categories.jsonl",
