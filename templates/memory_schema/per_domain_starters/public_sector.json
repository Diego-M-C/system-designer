          "confidence_pct": 92
        },
        {
          "name": "category",
          "type": "string",
          "flag": "mandatory",
          "rationale": "service line / topic",
          "confidence_pct": 90
        },
        {
          "name": "n_items",
          "type": "int",
          "flag": "mandatory",
          "rationale": "volume",
          "confidence_pct": 95
        },
        {
          "name": "sentiment_score",
          "type": "number -1.0..1.0",
          "flag": "mandatory",
          "rationale": "calibrated polarity",
          "confidence_pct": 80
        },
        {
          "name": "top_issues",
          "type": "array<string>",
          "flag": "mandatory",
          "rationale": "≤5 items",
          "confidence_pct": 85
        },
        {
          "name": "session_id",
          "type": "string",
          "flag": "mandatory",
          "rationale": "lineage",
          "confidence_pct": 95
        },
        {
          "name": "ts",
          "type": "ISO8601",
          "flag": "mandatory",
          "rationale": "ordering",
          "confidence_pct": 95
        }
      ],
      "audit": {
        "completeness_rule": "every entry has category AND n_items AND sentiment_score AND top_issues",
        "missing_threshold_pct": 5,
        "particular_audit": "feedback ingestion emits one entry per batch",
        "global_audit": "monthly: detect categories with rising negative-sentiment trends"
      },
      "added_by": "starter",
      "confidence_pct": 80,
      "non_removable_for_high_risk": true
    },
    {
      "name": "compliance_audit_trail",
      "format": "sqlite",
      "format_alternatives": [
        { "format": "jsonl",   "fit_pct": 50, "rationale": "append-only event log; loses FTS5 over evidence_path + indexed query 'failures without remediation in last 30 days'" },
        { "format": "parquet", "fit_pct": 30, "rationale": "columnar archive for very large compliance histories; loses interactive query" }
      ],
      "path": "memory/compliance_audit_trail.db",
      "tier_b_fallback": "not applicable (sqlite is Tier-A)",
      "trigger": "every compliance check with outcome",
      "append_only": true,
      "fields": [
        {
          "name": "check_id",
          "type": "string",
          "flag": "mandatory",
          "rationale": "stable handle",
          "confidence_pct": 92
        },
        {
          "name": "check_type",
          "type": "string",
          "flag": "mandatory",
          "rationale": "EU AI Act | GDPR | ISO 42001 | ...",
          "confidence_pct": 92
        },
        {
          "name": "outcome",
          "type": "enum {pass,fail,n/a,pending}",
          "flag": "mandatory",
          "rationale": "result",
          "confidence_pct": 95
        },
        {
          "name": "evidence_path",
          "type": "string|null",
          "flag": "mandatory_if_outcome=pass",
          "rationale": "trail",
          "confidence_pct": 88
        },
        {
          "name": "remediation",
          "type": "string|null",
          "flag": "mandatory_if_outcome=fail",
          "rationale": "plan",
          "confidence_pct": 85
        },
        {
          "name": "session_id",
          "type": "string",
          "flag": "mandatory",
          "rationale": "lineage",
          "confidence_pct": 95
        },
        {
          "name": "ts",
          "type": "ISO8601",
          "flag": "mandatory",
          "rationale": "ordering",
          "confidence_pct": 95
        }
      ],
      "audit": {
        "completeness_rule": "every entry has check_type AND outcome; pass has evidence_path; fail has remediation",
        "missing_threshold_pct": 1,
        "particular_audit": "every audit/audit_sheet.xlsx update emits ≥1 entry",
        "global_audit": "every 30 days: surface failures without remediation completed"
      },
      "added_by": "starter",
      "confidence_pct": 88,
      "non_removable_for_high_risk": true
    },
    {
      "name": "service_uptime_incidents",
