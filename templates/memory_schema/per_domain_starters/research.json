{
  "starter_id": "research",
  "schema_version": 1,
  "generator_version": "0.3.0",
  "domain": "research",
  "description": "Starter for research / academia projects. Anchored on hypothesis tracking and reproducibility discipline.",
  "modules": [
    {
      "name": "hypothesis_log",
      "format": "structured_md",
      "path": "memory/hypothesis_log.md",
      "trigger": "every hypothesis stated, refined, or refuted",
      "append_only": true,
      "fields": [
        { "name": "hypothesis_id",   "type": "string",  "flag": "mandatory","rationale": "stable handle",                      "confidence_pct": 92 },
        { "name": "statement",       "type": "string",  "flag": "mandatory","rationale": "the hypothesis itself",              "confidence_pct": 92 },
        { "name": "version",         "type": "int",     "flag": "mandatory","rationale": "revision counter",                    "confidence_pct": 95 },
        { "name": "supporting_evidence","type": "array<string>","flag": "recommended","rationale": "lineage to runs / data",   "confidence_pct": 80 },
        { "name": "status",          "type": "enum {open,supported,refuted,paused}","flag": "mandatory","rationale": "lifecycle","confidence_pct": 95 },
        { "name": "session_id",      "type": "string",  "flag": "mandatory","rationale": "lineage",                            "confidence_pct": 95 },
        { "name": "ts",              "type": "ISO8601", "flag": "mandatory","rationale": "ordering",                           "confidence_pct": 95 }
      ],
      "audit": {
        "completeness_rule": "every entry has statement AND version AND status",
        "missing_threshold_pct": 5,
        "particular_audit": "every Gate #1 plan declares ≥1 hypothesis_log entry",
        "global_audit": "every 5 sessions: hypotheses in 'open' for >30 days surface for review"
      },
      "added_by": "starter",
      "confidence_pct": 85
    },
    {
      "name": "experiment_runs",
      "format": "jsonl",
      "path": "memory/experiment_runs.jsonl",
      "trigger": "every experiment run",
      "append_only": true,
      "fields": [
        { "name": "run_id",            "type": "string",   "flag": "mandatory","rationale": "stable handle",        "confidence_pct": 95 },
        { "name": "hypothesis_id",     "type": "string",   "flag": "mandatory","rationale": "FK to hypothesis_log", "confidence_pct": 92 },
        { "name": "seed",              "type": "int",      "flag": "mandatory","rationale": "reproducibility",      "confidence_pct": 95 },
        { "name": "dataset_version",   "type": "string",   "flag": "mandatory","rationale": "FK to dataset_versioning","confidence_pct": 92 },
        { "name": "config_hash",       "type": "string",   "flag": "mandatory","rationale": "exact config",         "confidence_pct": 92 },
        { "name": "results_summary",   "type": "string",   "flag": "mandatory","rationale": "≤300 chars factual",   "confidence_pct": 88 },
        { "name": "primary_metric",    "type": "string",   "flag": "mandatory","rationale": "what we measured",     "confidence_pct": 90 },
        { "name": "primary_metric_value","type": "number", "flag": "mandatory","rationale": "the value",            "confidence_pct": 95 },
        { "name": "uncertainty_pct",   "type": "number",   "flag": "mandatory","rationale": "P2 ±range",            "confidence_pct": 88 },
        { "name": "session_id",        "type": "string",   "flag": "mandatory","rationale": "lineage",              "confidence_pct": 95 },
        { "name": "ts",                "type": "ISO8601",  "flag": "mandatory","rationale": "ordering",             "confidence_pct": 95 }
      ],
      "audit": {
        "completeness_rule": "every entry has hypothesis_id AND seed AND dataset_version AND config_hash AND primary_metric AND primary_metric_value AND uncertainty_pct",
        "missing_threshold_pct": 1,
        "particular_audit": "every benchmark / experiment session emits ≥1 entry",
        "global_audit": "every 10 runs: replication_attempts coverage >=20% of supported hypotheses"
      },
      "added_by": "starter",
      "confidence_pct": 90
    },
    {
      "name": "replication_attempts",
      "format": "jsonl",
      "path": "memory/replication_attempts.jsonl",
      "trigger": "every internal or external replication",
      "append_only": true,
      "fields": [
        { "name": "replication_id", "type": "string",  "flag": "mandatory","rationale": "stable handle",                  "confidence_pct": 92 },
        { "name": "original_run_id","type": "string",  "flag": "mandatory","rationale": "FK to experiment_runs",          "confidence_pct": 95 },
        { "name": "by",             "type": "enum {internal,external}","flag":"mandatory","rationale": "trust signal",  "confidence_pct": 95 },
        { "name": "outcome",        "type": "enum {match,partial,fail}","flag":"mandatory","rationale": "verdict",       "confidence_pct": 92 },
        { "name": "delta_pct",      "type": "number|null","flag": "mandatory_if_outcome!=match","rationale": "magnitude","confidence_pct": 88 },
        { "name": "session_id",     "type": "string",  "flag": "mandatory","rationale": "lineage",                       "confidence_pct": 95 },
        { "name": "ts",             "type": "ISO8601", "flag": "mandatory","rationale": "ordering",                      "confidence_pct": 95 }
      ],
      "audit": {
        "completeness_rule": "every entry has original_run_id AND by AND outcome",
        "missing_threshold_pct": 5,
        "particular_audit": "any new claim emits a candidate replication_attempts entry",
        "global_audit": "every 10 runs: replication coverage trend"
      },
      "added_by": "starter",
      "confidence_pct": 85
    },
    {
      "name": "peer_review_feedback",
      "format": "structured_md",
      "path": "memory/peer_review_feedback.md",
      "trigger": "every peer-review round",
      "append_only": true,
      "fields": [
        { "name": "review_id",       "type": "string", "flag": "mandatory","rationale": "stable handle",     "confidence_pct": 92 },
        { "name": "reviewer_handle", "type": "string", "flag": "mandatory","rationale": "anonymised",        "confidence_pct": 88 },
        { "name": "venue",           "type": "string", "flag": "mandatory","rationale": "where",              "confidence_pct": 90 },
        { "name": "comments_summary","type": "string", "flag": "mandatory","rationale": "≤500 chars",         "confidence_pct": 85 },
        { "name": "response_summary","type": "string", "flag": "mandatory","rationale": "what we changed",    "confidence_pct": 85 },
        { "name": "session_id",      "type": "string", "flag": "mandatory","rationale": "lineage",            "confidence_pct": 95 },
        { "name": "ts",              "type": "ISO8601","flag": "mandatory","rationale": "ordering",           "confidence_pct": 95 }
      ],
      "audit": {
        "completeness_rule": "every entry has venue AND comments_summary AND response_summary",
        "missing_threshold_pct": 5,
        "particular_audit": "every submission cycle emits one entry",
        "global_audit": "outstanding action items from reviews >30 days surface at HITL"
      },
      "added_by": "starter",
      "confidence_pct": 80
    },
    {
      "name": "dataset_versioning",
      "format": "jsonl",
      "path": "memory/dataset_versioning.jsonl",
      "trigger": "every dataset addition or version bump",
      "append_only": true,
      "fields": [
        { "name": "dataset_name", "type": "string",   "flag": "mandatory","rationale": "search key",            "confidence_pct": 95 },
        { "name": "version",      "type": "string",   "flag": "mandatory","rationale": "semver or hash",        "confidence_pct": 92 },
        { "name": "sha256",       "type": "string",   "flag": "mandatory","rationale": "integrity",             "confidence_pct": 95 },
        { "name": "provenance",   "type": "string",   "flag": "mandatory","rationale": "source",                 "confidence_pct": 90 },
        { "name": "license",      "type": "string",   "flag": "mandatory","rationale": "redistribution rights",  "confidence_pct": 92 },
        { "name": "session_id",   "type": "string",   "flag": "mandatory","rationale": "lineage",                "confidence_pct": 95 },
        { "name": "ts",           "type": "ISO8601",  "flag": "mandatory","rationale": "ordering",               "confidence_pct": 95 }
      ],
      "audit": {
        "completeness_rule": "every entry has dataset_name AND version AND sha256 AND provenance AND license",
        "missing_threshold_pct": 1,
        "particular_audit": "every experiment_runs.dataset_version resolves to a dataset_versioning entry",
        "global_audit": "monthly: surface datasets with no recent run referencing them"
      },
      "added_by": "starter",
      "confidence_pct": 88
    }
  ]
}
